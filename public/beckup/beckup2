<!-- market -->

<header id="main-header" class="hidden h-20 shrink-0 items-center justify-between px-8 border-b border-[#1f2329] fade-in">
    <div>
        <h2 id="header-greeting" class="text-2xl font-bold text-white">Selamat datang kembali! 👋</h2>
        <p class="text-sm text-gray-400 mt-1">Berikut adalah gambaran portofolio serta ringkasan pasar anda.</p>
    </div>
    <div class="flex items-center gap-3">
        <div class="text-right">
            <div id="wallet-name" class="font-semibold text-sm tracking-wide text-gray-500">Belum Login</div>
            <div id="wallet-status" class="text-[10px] green flex items-center justify-end gap-1 mt-0.5"><i class="bi bi-shield-lock-fill"></i> Offline</div>
        </div>
        <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg" class="w-8 h-8" alt="MetaMask" />
    </div>
</header>

<main id="main-layout" class="flex-1 overflow-y-auto px-8 py-8 flex gap-6">

    <div class="flex-1 flex flex-col gap-6 min-w-[650px]">
        
        <div class="panel p-6 bg-[#101216] border border-[#1f2329] rounded-2xl">
            <div class="flex justify-between items-start mb-6">
                <div>
                    <h3 class="font-semibold text-lg text-white">Market Coins</h3>
                    <p class="text-xs text-gray-500">Top Coins 24H</p>
                </div>
                <div class="border border-[#2b3139] rounded-full px-4 py-2 flex items-center gap-2">
                    <i class="bi bi-search text-xs text-gray-500"></i>
                    <input type="text" id="search-input" placeholder="Search Coin Name" class="bg-transparent text-xs text-white focus:outline-none w-32" />
                </div>
            </div>
            <div id="top-cards-container" class="grid grid-cols-4 gap-4"><div class="text-sm text-gray-500 animate-pulse">Memuat market...</div></div>
        </div>

        <div class="panel p-6 flex-1 flex flex-col min-h-[400px] bg-[#101216] border border-[#1f2329] rounded-2xl">
            <div class="flex gap-3 mb-6">
                <button class="bg-[#00d06c] text-black text-xs font-bold px-6 py-2 rounded-full">All</button>
                <button class="border border-[#2b3139] text-gray-400 hover:text-white hover:bg-[#2b3139] text-xs font-semibold px-6 py-2 rounded-full transition">Pocket</button>
                <button class="border border-[#2b3139] text-gray-400 hover:text-white hover:bg-[#2b3139] text-xs font-semibold px-6 py-2 rounded-full transition">Favorite</button>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-sm text-left text-white">
                    <thead class="border-b border-[#2b3139] text-gray-400 uppercase text-[11px] tracking-wider">
                        <tr><th class="pb-3 px-2 w-10">#</th><th class="pb-3">Coin Name</th><th class="pb-3">Coin Price</th><th class="pb-3">24H</th><th class="pb-3">24H High</th><th class="pb-3">24H Low</th><th class="pb-3 text-right pr-2">Chart</th></tr>
                    </thead>
                    <tbody id="market-table-body">
                        <tr><td colspan="7" class="py-10 text-center text-gray-500 animate-pulse">Memuat market...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="w-[320px] shrink-0 h-full relative">
        
        <div id="panel-login" class="bg-[#101216] border border-[#1f2329] rounded-2xl p-6 h-full flex flex-col items-center z-10 fade-in">
            <div class="flex-1 flex flex-col items-center justify-center w-full mt-10">
                <img src="https://upload.wikimedia.org/wikipedia/commons/3/36/MetaMask_Fox.svg" class="w-36 h-36 mb-6 drop-shadow-2xl hover:scale-105 transition" />
                <div class="text-center">
                    <div class="text-white text-[15px] mb-1">Login with</div>
                    <div class="text-[#e85d04] text-3xl logo-font font-bold">MetaMask</div>
                    <div class="text-gray-500 text-[11px] mt-2 tracking-wider">To Open Your Account</div>
                </div>
            </div>
            <div class="w-full mt-auto pt-6">
                <button onclick="connectWallet()" class="w-full bg-[#e85d04] text-white font-bold text-sm py-4 rounded-xl shadow-[0_4px_14px_0_rgba(232,93,4,0.39)] hover:bg-[#f3701a] hover:-translate-y-0.5 transition-all">Connect</button>
            </div>
        </div>

        <div id="panel-portfolio" class="hidden bg-[#101216] border border-[#1f2329] rounded-2xl p-6 h-full flex-col">
            
            <div class="mb-2">
                <div id="porto-total" class="text-4xl font-bold tracking-tight mb-1 text-white">$8,096.00</div>
                <div class="text-[#00d06c] text-xs font-medium">+ 1,032.09 (▲ 1.74%)</div>
            </div>
            
            <div class="relative h-24 border-b border-[#1f2329] flex items-center justify-center mb-6">
                <span class="absolute left-0 bottom-4 text-[9px] text-gray-600 font-mono tracking-wider">$7,063.91</span>
                <svg viewBox="0 0 100 30" class="w-full h-full opacity-60 px-2 mt-2"><path d="M0,20 L10,22 L20,25 L30,23 L40,24 L50,26 L60,25 L70,22 L80,24 L90,20 L100,15" fill="none" stroke="#6b7280" stroke-width="1.5"/></svg>
                <span class="absolute right-0 top-3 text-[9px] text-gray-600 font-mono tracking-wider">$8,096.00</span>
            </div>
            
            <div>
                <h3 class="font-semibold text-sm mb-4 text-white">Portofolio Saya</h3>
                <div id="porto-list" class="text-xs">
                    <div class="text-gray-500 animate-pulse">Memuat portfolio...</div>
                </div>
            </div>
            
            <div class="mt-8 flex-1">
                <h3 class="font-semibold text-sm mb-4 text-white">P&I</h3>
                <div class="h-24 flex items-end justify-between gap-1">
                    <div class="w-full h-[60%] bg-[#00d06c] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Jan</span></div>
                    <div class="w-full h-[40%] bg-[#f6465d] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Feb</span></div>
                    <div class="w-full h-[80%] bg-[#00d06c] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Mar</span></div>
                    <div class="w-full h-[90%] bg-[#f6465d] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Apr</span></div>
                    <div class="w-full h-[50%] bg-[#00d06c] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">May</span></div>
                    <div class="w-full h-[70%] bg-[#f6465d] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Jun</span></div>
                    <div class="w-full h-[100%] bg-[#00d06c] relative"><span class="absolute -bottom-5 left-1/2 -translate-x-1/2 text-[8px] text-gray-500">Jul</span></div>
                </div>
            </div>

            <div class="mt-10">
                <button class="w-full bg-[#00d06c] text-black font-bold text-xs py-3 px-4 rounded-lg shadow-lg flex items-center justify-between hover:bg-[#00e676] transition active:scale-95">
                    <div class="flex gap-1"><div class="w-3 h-3 bg-white rounded-sm"></div><div class="w-3 h-3 bg-white rounded-sm"></div></div>
                    <span>Minta Pendapat Bloop!</span>
                </button>
            </div>
        </div>
    </div>
</main>

<script>
    // ----------------------------------------------------
    // 1. SINKRONISASI UI LOGIN 
    // ----------------------------------------------------
    window.syncMarketUI = function() {
        if (!window.isWeb3Ready) return;
        
        // PENGAMANAN LAYOUT: Hapus panel login, ganti panel porto jadi flex (TIDAK PAKAI ABSOLUTE LAGI)
        const panelLogin = document.getElementById('panel-login');
        const panelPorto = document.getElementById('panel-portfolio');
        if (panelLogin && panelPorto) {
            panelLogin.classList.replace('flex', 'hidden');
            panelPorto.classList.replace('hidden', 'flex');
            panelPorto.classList.add('fade-in');
        }
        
        const header = document.getElementById('main-header');
        if (header) {
            header.classList.remove('hidden');
            header.classList.add('flex');
        }
        
        const layout = document.getElementById('main-layout');
        if (layout) {
            layout.classList.replace('py-8', 'pb-8');
            layout.classList.add('pt-2');
        }
        
        if (window.userAddress) {
            document.getElementById('header-greeting').innerText = `Selamat datang kembali, ${window.userAddress.substring(0,4)}...${window.userAddress.substring(window.userAddress.length-4)}! 👋`;
        }
        
        const wName = document.getElementById('wallet-name');
        const wStatus = document.getElementById('wallet-status');
        if (wName && wStatus) {
            wName.innerText = "MetaMask";
            wName.classList.replace('text-gray-500', 'text-white');
            wStatus.innerHTML = `<i class="bi bi-patch-check-fill text-[#00d06c]"></i> <span class="text-[#00d06c]">Verified Wallet</span>`;
        }
        
        fetchNodeJsPortfolio();
    };

    // ----------------------------------------------------
    // 2. FETCH DATA MARKET DARI COINGECKO
    // ----------------------------------------------------
    async function fetchCryptoData() {
        try {
            const res = await fetch('/api/crypto');
            if (!res.ok) throw new Error(`HTTP ${res.status}`);
            const data = await res.json();
            
            const cardsContainer = document.getElementById('top-cards-container');
            let cardsHtml = '';
            
            data.slice(0, 4).forEach(coin => {
                const percent = coin.price_change_percentage_24h ?? 0;
                const isPos = percent >= 0;
                const colorClass = isPos ? 'text-[#00d06c]' : 'text-[#f6465d]';
                const arrow = isPos ? '▲' : '▼';
                const targetSymbol = (coin.symbol || '').toUpperCase() + 'USDT';
                
                cardsHtml += `
                <div onclick="navigate('/trade?symbol=${targetSymbol}')" class="bg-[#0b0e11] border border-[#1f2329] p-4 rounded-xl flex flex-col justify-between hover:border-[#00d06c] transition cursor-pointer">
                    <div class="flex justify-between items-center mb-4">
                        <div class="flex items-center gap-2">
                            <img src="${coin.image}" class="w-6 h-6 rounded-full" alt="${coin.symbol}">
                            <span class="font-medium text-white text-sm">${coin.name}</span>
                        </div>
                    </div>
                    <div class="flex justify-between items-end">
                        <div>
                            <div class="text-white font-bold text-[13px]">$${(coin.current_price || 0).toLocaleString('en-US')}</div>
                            <div class="${colorClass} text-[10px] mt-1">${isPos ? '+' : ''}${percent.toFixed(2)}% ${arrow}</div>
                        </div>
                        <div id="chart-card-${coin.id}" class="w-16"></div>
                    </div>
                </div>`;
            });
            if(cardsContainer) cardsContainer.innerHTML = cardsHtml;

            const tableBody = document.getElementById('market-table-body');
            let tableHtml = '';
            
            data.forEach((coin, i) => {
                const percent = coin.price_change_percentage_24h ?? 0;
                const isPos = percent >= 0;
                const colorClass = isPos ? 'text-[#00d06c]' : 'text-[#f6465d]';
                const arrow = isPos ? '▲' : '▼';
                const targetSymbol = (coin.symbol || '').toUpperCase() + 'USDT';
                
                tableHtml += `
                <tr onclick="navigate('/trade?symbol=${targetSymbol}')" class="border-b border-[#1f2329] hover:bg-[#1f2329]/50 transition group cursor-pointer">
                    <td class="py-4 px-2 text-gray-500 text-xs">${i + 1}</td>
                    <td class="py-4 flex items-center gap-3 text-white text-sm font-medium">
                        <img src="${coin.image}" class="w-5 h-5 rounded-full" alt="${coin.symbol}"> 
                        ${coin.name}
                    </td>
                    <td class="py-4 text-white text-sm">$${(coin.current_price || 0).toLocaleString('en-US', {minimumFractionDigits: 2, maximumFractionDigits: 6})}</td>
                    <td class="py-4 ${colorClass} text-xs">${isPos ? '+' : ''}${percent.toFixed(2)}% ${arrow}</td>
                    <td class="py-4 ${colorClass} text-xs">+${percent.toFixed(2)}% ${arrow}</td>
                    <td class="py-4 ${colorClass} text-xs">+${percent.toFixed(2)}% ${arrow}</td>
                    <td class="py-4 text-right pr-2">
                        <div id="chart-table-${coin.id}" class="inline-block w-16 opacity-80 group-hover:opacity-100 transition"></div>
                    </td>
                </tr>`;
            });
            if(tableBody) tableBody.innerHTML = tableHtml;

            setTimeout(() => {
                data.slice(0, 4).forEach(coin => {
                    if (coin.sparkline_in_7d && coin.sparkline_in_7d.price) {
                        renderSparkline(`chart-card-${coin.id}`, coin.sparkline_in_7d.price);
                    }
                });
                data.forEach(coin => {
                    if (coin.sparkline_in_7d && coin.sparkline_in_7d.price) {
                        renderSparkline(`chart-table-${coin.id}`, coin.sparkline_in_7d.price);
                    }
                });
                searchMarketCoin();
            }, 100);

        } catch (err) {}
    }

    // ----------------------------------------------------
    // 3. RENDER APEXCHARTS SPARKLINE
    // ----------------------------------------------------
    function renderSparkline(id, seriesData) {
        const el = document.getElementById(id);
        if (!el || !Array.isArray(seriesData) || seriesData.length === 0) return;
        new ApexCharts(el, {
            chart: { type: 'line', height: 28, width: 60, sparkline: { enabled: true }, animations: { enabled: false } },
            stroke: { curve: 'smooth', width: 1.5, colors: ['#00d06c'] },
            series: [{ data: seriesData }],
            tooltip: { enabled: false }
        }).render();
    }

    // ----------------------------------------------------
    // 4. FETCH PORTOFOLIO DENGAN FALLBACK DUMMY DATA
    // ----------------------------------------------------
    async function fetchNodeJsPortfolio() {
        if(!window.isWeb3Ready) return; 
        try {
            const res = await fetch('/api/portfolio');
            const data = await res.json();
            const list = document.getElementById('porto-list');
            if (!list) return;

            // JIKA USER BELUM TRANSAKSI, TAMPILKAN DUMMY DATA SEPERTI DESAIN MOCKUP!
            if (!data.positions || data.positions.length === 0) {
                list.innerHTML = `
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2 text-white"><span class="w-5 h-5 rounded-full bg-[#f7931a] flex items-center justify-center"><i class="bi bi-currency-bitcoin text-[10px] text-white"></i></span> Bitcoin</div>
                        <span class="text-[#00d06c]">+3% ▲</span><span class="text-white font-medium">$360,023.09</span>
                    </div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2 text-white"><span class="w-5 h-5 rounded-full bg-[#627eea] flex items-center justify-center"><i class="bi bi-currency-bitcoin text-[10px] text-white"></i></span> Ethereum</div>
                        <span class="text-[#00d06c]">+2% ▲</span><span class="text-white font-medium">$143,234.12</span>
                    </div>
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2 text-white"><span class="w-5 h-5 rounded-full bg-[#eb1c22] flex items-center justify-center"><i class="bi bi-currency-bitcoin text-[10px] text-white"></i></span> Tron</div>
                        <span class="text-[#f6465d]">-1% ▼</span><span class="text-white font-medium">$23,435.43</span>
                    </div>
                    <div class="text-center text-[10px] text-gray-600 mt-2 pt-2 border-t border-[#1f2329]">Data simulasi (Anda belum memiliki transaksi)</div>
                `;
                return;
            }

            // JIKA ADA TRANSAKSI, TAMPILKAN DATA ASLI
            document.getElementById('porto-total').innerText = `$${(data.balance || 0).toLocaleString('en-US', {minimumFractionDigits: 2})}`;
            let html = '';
            data.positions.forEach(pos => {
                const total = (pos.qty || 0) * (pos.entryPrice || 0);
                const cleanSymbol = pos.symbol.replace('/USDT', '');
                html += `
                    <div class="flex items-center justify-between mb-3">
                        <div class="flex items-center gap-2 text-white">
                            <span class="w-5 h-5 rounded-full bg-[#f7931a] flex items-center justify-center">
                                <i class="bi bi-currency-bitcoin text-[10px] text-white"></i>
                            </span>
                            ${cleanSymbol}
                        </div>
                        <span class="text-[#00d06c]">+3% ▲</span>
                        <span class="text-white font-medium">$${total.toLocaleString('en-US')}</span>
                    </div>`;
            });
            list.innerHTML = html;

        } catch (err) {}
    }

    // ----------------------------------------------------
    // 5. FITUR SEARCH BAR
    // ----------------------------------------------------
    function searchMarketCoin() {
        const searchInput = document.getElementById('search-input');
        if (!searchInput) return;
        const input = searchInput.value.toLowerCase();
        const rows = document.getElementById('market-table-body')?.getElementsByTagName('tr') || [];

        for (let i = 0; i < rows.length; i++) {
            const textValue = rows[i].textContent || rows[i].innerText;
            rows[i].style.display = textValue.toLowerCase().indexOf(input) > -1 ? '' : 'none';
        }
    }
    document.getElementById('search-input')?.addEventListener('keyup', searchMarketCoin);

    // ----------------------------------------------------
    // 6. INISIALISASI SAAT KOMPONEN DIMUAT
    // ----------------------------------------------------
    window.syncMarketUI();
    fetchCryptoData();

    window.marketInterval = setInterval(fetchCryptoData, 10000);
    window.portoInterval = setInterval(fetchNodeJsPortfolio, 3000);

</script>